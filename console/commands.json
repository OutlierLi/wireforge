{
  "build": {
    "desc": "Build protocol frame from target info. Sub-commands: --resolve (show input schema)",
    "module": "console.handlers.build",
    "handler": "handle",
    "enabled": true,
    "params": {
      "proto": {
        "type": "choice",
        "required": true,
        "desc": "协议类型",
        "examples": [
          "dlt645",
          "csg"
        ]
      },
      "func": {
        "type": "hex",
        "required": false,
        "desc": "功能码 (DLT645)",
        "examples": [
          "0x11",
          "0x13"
        ]
      },
      "afn": {
        "type": "hex",
        "required": false,
        "desc": "应用功能码 (CSG)",
        "examples": [
          "0x00",
          "0x03"
        ]
      },
      "di": {
        "type": "str",
        "required": false,
        "desc": "数据标识DI",
        "examples": [
          "00010000",
          "E8020701"
        ]
      },
      "dir": {
        "type": "choice",
        "required": false,
        "desc": "传输方向",
        "examples": [
          "downlink",
          "uplink"
        ],
        "default": "downlink"
      },
      "resolve": {
        "type": "bool",
        "required": false,
        "desc": "仅解析目标返回input_schema，不构造帧"
      },
      "*": {
        "type": "dynamic",
        "required": false,
        "desc": "业务字段由resolve后动态决定"
      }
    },
    "sub_commands": {
      "--resolve": "Resolve target only, return input_schema without building frame",
      "--describe": "Alias for --resolve"
    }
  },
  "decode": {
    "desc": "Decode raw hex frame to structured fields and route path",
    "module": "console.handlers.decode",
    "handler": "handle",
    "enabled": true,
    "params": {
      "proto": {
        "type": "choice",
        "required": true,
        "desc": "协议类型",
        "examples": [
          "dlt645",
          "csg"
        ]
      },
      "hex": {
        "type": "str",
        "required": true,
        "desc": "十六进制报文字节流",
        "examples": [
          "FE FE 68 ... 16",
          "68 0C 00 40 03 01 01 03 00 E8 30 16"
        ]
      }
    }
  },
  "auto_rule": {
    "desc": "Auto-reply rule engine. Sub: add, list, show, enable, disable, delete, test, load, history",
    "module": "console.handlers.auto_rule",
    "handler": "handle",
    "enabled": true,
    "params": {
      "sub": {
        "type": "choice",
        "required": true,
        "desc": "子命令",
        "examples": [
          "add",
          "list",
          "load",
          "test",
          "show",
          "enable",
          "disable",
          "delete",
          "history"
        ]
      },
      "id": {
        "type": "str",
        "desc": "规则ID"
      },
      "name": {
        "type": "str",
        "desc": "规则名称"
      },
      "hex": {
        "type": "str",
        "desc": "测试用十六进制报文"
      },
      "file": {
        "type": "str",
        "desc": "YAML规则文件路径"
      },
      "match": {
        "type": "str",
        "desc": "正则匹配模式 (regex)"
      },
      "source": {
        "type": "str",
        "desc": "触发源 serial:default"
      },
      "then": {
        "type": "str",
        "desc": "匹配后执行的命令"
      }
    },
    "sub_commands": {
      "add": "Add a new rule with match condition and actions",
      "list": "List all registered rules",
      "show": "Show full details of a rule by id",
      "enable": "Enable a disabled rule",
      "disable": "Disable a rule without deleting",
      "delete": "Permanently remove a rule",
      "test": "Test a rule against a hex frame (dry-run)",
      "load": "Load rules from YAML file",
      "history": "Show rule match history, optionally filtered by id"
    }
  },
  "serial": {
    "desc": "Serial port management. Sub: connect, open, close, send, set, disconnect, ports",
    "module": "console.handlers.serial_cmd",
    "handler": "handle",
    "enabled": true,
    "params": {
      "sub": {
        "type": "choice",
        "required": false,
        "desc": "子命令",
        "examples": [
          "connect",
          "open",
          "close",
          "send",
          "set",
          "disconnect",
          "ports"
        ]
      },
      "port": {
        "type": "str",
        "desc": "串口号",
        "examples": [
          "mock://loop",
          "virtual://demo",
          "/dev/ttyUSB0",
          "COM3"
        ],
        "note": "mock=内存回环, virtual=跨进程总线, 其他=物理串口"
      },
      "baudrate": {
        "type": "int",
        "desc": "波特率",
        "examples": [
          9600,
          115200
        ],
        "note": "set 修改后需 /serial open 生效，不能热修改已打开的串口"
      },
      "parity": {
        "type": "choice",
        "desc": "校验位",
        "examples": [
          "N",
          "E",
          "O"
        ],
        "note": "set 修改后需 /serial open 生效"
      },
      "bytesize": {
        "type": "int",
        "desc": "数据位",
        "examples": [
          8
        ],
        "note": "set 修改后需 /serial open 生效"
      },
      "hex": {
        "type": "str",
        "desc": "发送数据(十六进制)"
      },
      "timeout": {
        "type": "int",
        "desc": "超时(秒)"
      }
    },
    "sub_commands": {
      "connect": "First-time connection with port/baudrate/parity params",
      "open": "Re-open last connection without re-specifying params",
      "close": "Close current serial connection",
      "send": "Send hex frame and wait for response",
      "set": "Change serial params (takes effect on next open)",
      "disconnect": "Alias for close",
      "ports": "List available serial ports and connection status"
    }
  },
  "help": {
    "desc": "Show command help. /help /serial or /help \"/serial open\"",
    "module": "console.handlers.help",
    "handler": "handle",
    "enabled": true,
    "params": {
      "target": {
        "type": "str",
        "required": false,
        "desc": "Command name, e.g. /serial",
        "examples": [
          "/serial",
          "/serial open"
        ]
      }
    }
  }
}